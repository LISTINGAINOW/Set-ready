 primary bathroom","glass walk-in shower","dual vanities","walk-in closet with built-ins","music studio/workstation","natural light","modern finishes","hillside exterior","flex lounge area"],"photos":["/images/properties/hillside-view-la/01.jpg","/images/properties/hillside-view-la/02.jpg","/images/properties/hillside-view-la/03.jpg","/images/properties/hillside-view-la/04.jpg","/images/properties/hillside-view-la/05.jpg","/images/properties/hillside-view-la/06.jpg","/images/properties/hillside-view-la/07.jpg","/images/properties/hillside-view-la/08.jpg","/images/properties/hillside-view-la/09.jpg","/images/properties/hillside-view-la/10.jpg","/images/properties/hillside-view-la/11.jpg","/images/properties/hillside-view-la/12.jpg","/images/properties/hillside-view-la/13.jpg","/images/properties/hillside-view-la/14.jpg","/images/properties/hillside-view-la/15.jpg","/images/properties/hillside-view-la/16.jpg","/images/properties/hillside-view-la/17.jpg","/images/properties/hillside-view-la/18.jpg","/images/properties/hillside-view-la/19.jpg","/images/properties/hillside-view-la/20.jpg"],"squareFootage":5000,"rooms":4,"specialFeatures":["Curved lounge with canyon views","Indoor round jacuzzi tub","Music studio/workstation","Rooftop access via spiral stair"],"neighborhood":"Los Angeles, CA - Secluded hillside setting","tags":["🎥 Content Creation","🎬 Film/TV","🎵 Music Videos","📸 Photography"],"bedrooms":4,"bathrooms":3,"styleTags":["Contemporary","Modern","Architectural"],"lotSize":7000,"parkingSpots":3,"maxAttendees":15,"minimumBookingHours":4,"mainFloorNumber":1,"parkingDetails":"On-site hillside parking with nearby street options shared upon inquiry.","accessOptions":["Multi-level interior access","Balcony access","Rooftop access via spiral staircase"],"features":["Expansive picture windows","Sunburst ceiling detail","Spa-style primary suite","Media/projection area","Custom walk-in closet"],"openingHours":{"Monday":"8:00 AM - 10:00 PM","Tuesday":"8:00 AM - 10:00 PM","