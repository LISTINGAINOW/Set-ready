4:{"id":"hillside-view-los-angeles","title":"Contemporary Hillside View Home in Los Angeles","city":"Los Angeles","state":"CA","address":"Los Angeles Hillside Area","description":"Large multi-level contemporary hillside residence with striking architectural lines, expansive windows, and strong natural light throughout. The home features a dramatic great room with dark wood floors, a curved window lounge beneath a custom sunburst ceiling detail, fireplace, projection/media area, multiple balconies, and rooftop access via spiral stair. The primary suite is especially distinctive, with a spacious bedroom, studio/workstation area, indoor round jacuzzi soaking tub, fireplace, oversized spa-style bathroom with dual vanities and glass walk-in shower, plus a large custom walk-in closet. Additional lounge space with oversized windows and canyon views adds flexibility for filming, interviews, lifestyle shoots, music content, and upscale indoor scenes. The property feels secluded and visually unique, with a clean modern palette, hillside outlooks, and multiple shoot-ready angles.","price":450,"privacyTier":"Discrete","propertyType":"house","contentTypes":"$5","amenities":"$6","photos":"$7","squareFootage":5000,"rooms":4,"specialFeatures":"$8","neighborhood":"Los Angeles, CA - Secluded hillside setting","tags":"$9","bedrooms":4,"bathrooms":3,"styleTags":"$a","lotSize":7000,"parkingSpots":3,"maxAttendees":15,"minimumBookingHours":4,"mainFloorNumber":1,"parkingDetails":"On-site hillside parking with nearby street options shared upon inquiry.","accessOptions":"$b","features":"$c","openingHours":"$d","locationRules":"$e","kitchenFacilities":"Light prep and hospitality support can be accommodated with advance notice.","cateringOptions":"Outside catering allowed with prior approval and crew footprint planning.","alcoholPolicy":"Permitted for scene use and approved productions only.","musicPolicy":"Playback and light recording setup allowed; amplified sound subject to neighborhood discretion.","paSystem":false,"bringYourOwnMusic":true,"greatRate":false,"adultFriendlyVerified":true,"aiAssistantAvailable":true,"reviewRating":4.9,"reviewCount":0,"reviewQuote":"Architectural hillside modern with canyon views, curved lounge, spa primary suite, indoor jacuzzi, balconies, and music studio setup.","privacyNotice":"Exact location and detailed access notes are shared only after qualified inquiry or booking confirmation.","bookings":"$17","cancellationPolicy":"Flexible","houseRules":"$18","isVerified":true,"verificationBadges":"$19","responseTime":"Responds within 1 hour","securityDeposit":1200,"securityDepositRequiredWhen":"Always"}
