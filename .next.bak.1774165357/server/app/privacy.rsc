0:["WqBKyu7oPc6XybhnJMaJx",[[["",{"children":["privacy",{"children":["__PAGE__",{}]}]},"$undefined","$undefined",true],["",{"children":["privacy",{"children":["__PAGE__",{},[["$L1",["$","main",null,{"className":"min-h-screen bg-gradient-to-b from-white to-blue-50 px-4 py-12 sm:px-6 lg:px-8 lg:py-16","children":["$","div",null,{"className":"mx-auto max-w-4xl rounded-[32px] border border-blue-100 bg-white p-8 shadow-[0_24px_70px_rgba(15,23,42,0.08)] sm:p-10 lg:p-12","children":[["$","div",null,{"className":"max-w-3xl","children":[["$","p",null,{"className":"text-sm font-semibold uppercase tracking-[0.28em] text-blue-600","children":"Legal"}],["$","h1",null,{"className":"mt-4 text-4xl font-semibold tracking-[-0.05em] text-black sm:text-5xl","children":"Privacy Policy"}],["$","p",null,{"className":"mt-5 text-base leading-8 text-black/70 sm:text-lg","children":"This Privacy Policy explains what information Discreet Set collects, how we use it, and how privacy is handled on a platform designed for sensitive location bookings and adult-industry workflows."}]]}],["$","div",null,{"className":"mt-10 space-y-8","children":[["$","section","1. Information We Collect",{"id":"1-information-we-collect","className":"rounded-[24px] border border-blue-100 bg-blue-50/70 p-6 sm:p-7","children":[["$","h2",null,{"className":"text-2xl font-semibold tracking-[-0.04em] text-black","children":"1. Information We Collect"}],["$","div",null,{"className":"mt-4 space-y-4 text-sm leading-7 text-black/80 sm:text-base","children":[["$","p","We may collect information you provide directly, including your name, email address, phone number, business details, account credentials, listing details, communications, and booking information.",{"children":"We may collect information you provide directly, including your name, email address, phone number, business details, account credentials, listing details, communications, and booking information."}],["$","p","We may also collect payment-related information through our payment processors, location-related information connected to listings or searches, device and browser information, log data, and usage analytics.",{"children":"We may also collect payment-related information through our payment processors, location-related information connected to listings or searches, device and browser information, log data, and usage analytics."}],["$","p","Because Discreet Set serves privacy-sensitive productions, some information may relate to listing privacy preferences, approximate or exact property location, and booking verification details.",{"children":"Because Discreet Set serves privacy-sensitive productions, some information may relate to listing privacy preferences, approximate or exact property location, and booking verification details."}]]}]]}],["$","section","2. How We Use Information",{"id":"2-how-we-use-information","className":"rounded-[24px] border border-blue-100 bg-blue-50/70 p-6 sm:p-7","children":[["$","h2",null,{"className":"text-2xl font-semibold tracking-[-0.04em] text-black","children":"2. How We Use Information"}],["$","div",null,{"className":"mt-4 space-y-4 text-sm leading-7 text-black/80 sm:text-base","children":[["$","p","We use information to operate the platform, create and manage accounts, process bookings, facilitate communication between users, verify eligibility, detect misuse, and provide customer support.",{"children":"We use information to operate the platform, create and manage accounts, process bookings, facilitate communication between users, verify eligibility, detect misuse, and provide customer support."}],["$","p","We may also use information to improve platform performance, analyze trends, develop new features, personalize user experience, and enforce our terms, policies, and legal obligations.",{"children":"We may also use information to improve platform performance, analyze trends, develop new features, personalize user experience, and enforce our terms, policies, and legal obligations."}],["$","p","Where permitted, we may send service-related notices, verification messages, transactional communications, and limited product updates relevant to your account or activity.",{"children":"Where permitted, we may send service-related notices, verification messages, transactional communications, and limited product updates relevant to your account or activity."}]]}]]}],["$","section","3. Privacy Tiers and Location Privacy",{"id":"3-privacy-tiers-and-location-privacy","className":"rounded-[24px] border border-blue-100 bg-blue-50/70 p-6 sm:p-7","children":[["$","h2",null,{"className":"text-2xl font-semibold tracking-[-0.04em] text-black","children":"3. Privacy Tiers and Location Privacy"}],["$","div",null,{"className":"mt-4 space-y-4 text-sm leading-7 text-black/80 sm:text-base","children":[["$","p","Discreet Set supports privacy tiers such as Public, Discrete, and NDA Required to give hosts more control over how location details are exposed during discovery and booking.",{"children":"Discreet Set supports privacy tiers such as Public, Discrete, and NDA Required to give hosts more control over how location details are exposed during discovery and booking."}],["$","p","Depending on the selected tier, users may see broad location information, limited identifying details, or only partial listing content until inquiry, approval, or confidentiality steps are completed.",{"children":"Depending on the selected tier, users may see broad location information, limited identifying details, or only partial listing content until inquiry, approval, or confidentiality steps are completed."}],["$","p","Users who receive restricted listing information agree to use it only for legitimate booking evaluation and not to copy, publish, or disclose that information outside the intended transaction process.",{"children":"Users who receive restricted listing information agree to use it only for legitimate booking evaluation and not to copy, publish, or disclose that information outside the intended transaction process."}]]}]]}],["$","section","4. Data Protection",{"id":"4-data-protection","className":"rounded-[24px] border border-blue-100 bg-blue-50/70 p-6 sm:p-7","children":[["$","h2",null,{"className":"text-2xl font-semibold tracking-[-0.04em] text-black","children":"4. Data Protection"}],["$","div",null,{"className":"mt-4 space-y-4 text-sm leading-7 text-black/80 sm:text-base","children":[["$","p","We use reasonable administrative, technical, and organizational safeguards designed to protect personal information against unauthorized access, disclosure, alteration, or destruction.",{"children":"We use reasonable administrative, technical, and organizational safeguards designed to protect personal information against unauthorized access, disclosure, alteration, or destruction."}],["$","p","These safeguards may include access controls, encrypted transmission where appropriate, service-provider security controls, account verification tools, and internal limitations on who can access sensitive data.",{"children":"These safeguards may include access controls, encrypted transmission where appropriate, service-provider security controls, account verification tools, and internal limitations on who can access sensitive data."}],["$","p","No method of transmission or storage is completely secure, so we cannot guarantee absolute security.",{"children":"No method of transmission or storage is completely secure, so we cannot guarantee absolute security."}]]}]]}],["$","section","5. Cookies and Tracking",{"id":"5-cookies-and-tracking","className":"rounded-[24px] border border-blue-100 bg-blue-50/70 p-6 sm:p-7","children":[["$","h2",null,{"className":"text-2xl font-semibold tracking-[-0.04em] text-black","children":"5. Cookies and Tracking"}],["$","div",null,{"className":"mt-4 space-y-4 text-sm leading-7 text-black/80 sm:text-base","children":[["$","p","We may use cookies, local storage, session technologies, and similar tools to keep users signed in, remember preferences, maintain session integrity, understand traffic patterns, and improve site functionality.",{"children":"We may use cookies, local storage, session technologies, and similar tools to keep users signed in, remember preferences, maintain session integrity, understand traffic patterns, and improve site functionality."}],["$","p","We may also use analytics tools to measure usage, diagnose issues, and understand which features are most useful. You can often control cookies through your browser settings, though some features may not function properly if disabled.",{"children":"We may also use analytics tools to measure usage, diagnose issues, and understand which features are most useful. You can often control cookies through your browser settings, though some features may not function properly if disabled."}]]}]]}],["$","section","6. Third-Party Services",{"id":"6-third-party-services","className":"rounded-[24px] border border-blue-100 bg-blue-50/70 p-6 sm:p-7","children":[["$","h2",null,{"className":"text-2xl font-semibold tracking-[-0.04em] text-black","children":"6. Third-Party Services"}],["$","div",null,{"className":"mt-4 space-y-4 text-sm leading-7 text-black/80 sm:text-base","children":[["$","p","We may rely on third-party providers for services such as payment processing, hosting, analytics, mapping, communications, identity or fraud checks, and customer support tools.",{"children":"We may rely on third-party providers for services such as payment processing, hosting, analytics, mapping, communications, identity or fraud checks, and customer support tools."}],["$","p","Those providers may process personal information on our behalf or under their own privacy terms, depending on the service involved. We encourage users to review the privacy practices of relevant third-party providers where appropriate.",{"children":"Those providers may process personal information on our behalf or under their own privacy terms, depending on the service involved. We encourage users to review the privacy practices of relevant third-party providers where appropriate."}]]}]]}],["$","section","7. User Rights",{"id":"7-user-rights","className":"rounded-[24px] border border-blue-100 bg-blue-50/70 p-6 sm:p-7","children":[["$","h2",null,{"className":"text-2xl font-semibold tracking-[-0.04em] text-black","children":"7. User Rights"}],["$","div",null,{"className":"mt-4 space-y-4 text-sm leading-7 text-black/80 sm:text-base","children":[["$","p","Subject to applicable law, you may have the right to request access to personal information we hold about you, request correction of inaccurate information, request deletion of certain data, or object to or limit certain processing.",{"children":"Subject to applicable law, you may have the right to request access to personal information we hold about you, request correction of inaccurate information, request deletion of certain data, or object to or limit certain processing."}],["$","p","You may also request account closure, though we may retain certain information where required for legal, security, fraud-prevention, accounting, dispute-resolution, or contractual reasons.",{"children":"You may also request account closure, though we may retain certain information where required for legal, security, fraud-prevention, accounting, dispute-resolution, or contractual reasons."}],["$","p","To exercise privacy-related rights, contact us at support@discreetset.com.",{"children":"To exercise privacy-related rights, contact us at support@discreetset.com."}]]}]]}],["$","section","8. Data Retention",{"id":"8-data-retention","className":"rounded-[24px] border border-blue-100 bg-blue-50/70 p-6 sm:p-7","children":[["$","h2",null,{"className":"text-2xl font-semibold tracking-[-0.04em] text-black","children":"8. Data Retention"}],["$","div",null,{"className":"mt-4 space-y-4 text-sm leading-7 text-black/80 sm:text-base","children":[["$","p","We retain personal information for as long as reasonably necessary to provide the platform, maintain business records, resolve disputes, enforce agreements, comply with legal obligations, and protect platform integrity.",{"children":"We retain personal information for as long as reasonably necessary to provide the platform, maintain business records, resolve disputes, enforce agreements, comply with legal obligations, and protect platform integrity."}],["$","p","Retention periods may vary depending on the type of information, the nature of the booking or listing, payment and tax requirements, legal compliance needs, and safety or fraud concerns.",{"children":"Retention periods may vary depending on the type of information, the nature of the booking or listing, payment and tax requirements, legal compliance needs, and safety or fraud concerns."}]]}]]}],["$","section","9. Adult Industry and Legal Compliance",{"id":"9-adult-industry-and-legal-compliance","className":"rounded-[24px] border border-blue-100 bg-blue-50/70 p-6 sm:p-7","children":[["$","h2",null,{"className":"text-2xl font-semibold tracking-[-0.04em] text-black","children":"9. Adult Industry and Legal Compliance"}],["$","div",null,{"className":"mt-4 space-y-4 text-sm leading-7 text-black/80 sm:text-base","children":[["$","p","Discreet Set may be used by participants in the adult content industry. All users must be 18 years old or older, or the age of majority in their jurisdiction, whichever is higher.",{"children":"Discreet Set may be used by participants in the adult content industry. All users must be 18 years old or older, or the age of majority in their jurisdiction, whichever is higher."}],["$","p","Users are responsible for ensuring that all content, productions, bookings, and location use are legal, consensual, and properly documented under applicable law. We do not permit illegal, exploitative, or non-consensual conduct or content on the platform.",{"children":"Users are responsible for ensuring that all content, productions, bookings, and location use are legal, consensual, and properly documented under applicable law. We do not permit illegal, exploitative, or non-consensual conduct or content on the platform."}]]}]]}],["$","section","10. Contact for Privacy Issues",{"id":"10-contact-for-privacy-issues","className":"rounded-[24px] border border-blue-100 bg-blue-50/70 p-6 sm:p-7","children":[["$","h2",null,{"className":"text-2xl font-semibold tracking-[-0.04em] text-black","children":"10. Contact for Privacy Issues"}],["$","div",null,{"className":"mt-4 space-y-4 text-sm leading-7 text-black/80 sm:text-base","children":[["$","p","If you have questions, requests, or complaints related to this Privacy Policy or your personal information, contact support@discreetset.com.",{"children":"If you have questions, requests, or complaints related to this Privacy Policy or your personal information, contact support@discreetset.com."}],["$","p","We may update this Privacy Policy from time to time. When we do, we will post the updated version on this page, and your continued use of the platform will be subject to the revised policy.",{"children":"We may update this Privacy Policy from time to time. When we do, we will post the updated version on this page, and your continued use of the platform will be subject to the revised policy."}]]}]]}]]}]]}]}],null],null],null]},[null,["$","$L2",null,{"parallelRouterKey":"children","segmentPath":["children","privacy","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/e9fda707d02ffcd3.css","precedence":"next","crossOrigin":"$undefined"}],["$","link","1",{"rel":"stylesheet","href":"/_next/static/css/857aa62baa17c894.css","precedence":"next","crossOrigin":"$undefined"}]],["$","html",null,{"lang":"en","className":"__variable_f367f3","children":["$","body"