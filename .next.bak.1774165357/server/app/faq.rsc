"$","h2",null,{"className":"mt-3 text-2xl font-semibold tracking-[-0.04em] text-black","children":"What do the privacy tiers mean?"}],["$","p",null,{"className":"mt-4 text-base leading-7 text-black/75","children":"Public listings share more upfront detail. Discrete listings limit identifying information until a serious inquiry is made. NDA Required listings may require a signed confidentiality agreement before exact address details, additional photos, or sensitive production notes are released."}]]}],["$","section","What payment methods do you support?",{"className":"rounded-[28px] border border-black bg-[#FAFAFA] p-6 sm:p-7","children":[["$","p",null,{"className":"text-sm font-semibold uppercase tracking-[0.24em] text-blue-600","children":["Question ",3]}],["$","h2",null,{"className":"mt-3 text-2xl font-semibold tracking-[-0.04em] text-black","children":"What payment methods do you support?"}],["$","p",null,{"className":"mt-4 text-base leading-7 text-black/75","children":"Payment support depends on the processor connected to the platform. The booking flow is designed for professional production payments, transparent fees, and adult-friendly compliance rather than consumer-grade shortcuts that create risk for the business."}]]}],["$","section","What is the cancellation policy?",{"className":"rounded-[28px] border border-black bg-[#FAFAFA] p-6 sm:p-7","children":[["$","p",null,{"className":"text-sm font-semibold uppercase tracking-[0.24em] text-blue-600","children":["Question ",4]}],["$","h2",null,{"className":"mt-3 text-2xl font-semibold tracking-[-0.04em] text-black","children":"What is the cancellation policy?"}],["$","p",null,{"className":"mt-4 text-base leading-7 text-black/75","children":"Unless a listing says otherwise, cancellations should be made as early as possible. Refunds, credits, or rescheduling depend on the booking terms shown at checkout, the host policy, and whether the cancellation affects a confirmed production date."}]]}],["$","section","How does the NDA process work?",{"className":"rounded-[28px] border border-black bg-[#FAFAFA] p-6 sm:p-7","children":[["$","p",null,{"className":"text-sm font-semibold uppercase tracking-[0.24em] text-blue-600","children":["Question ",5]}],["$","h2",null,{"className":"mt-3 text-2xl font-semibold tracking-[-0.04em] text-black","children":"How does the NDA process work?"}],["$","p",null,{"className":"mt-4 text-base leading-7 text-black/75","children":"For NDA Required listings, producers may be asked to sign a confidentiality agreement before receiving exact property details. This helps protect hosts who need stricter privacy around address disclosure, interiors, or repeat-use production spaces."}]]}],["$","section","What are the requirements to host on Discreet Set?",{"className":"rounded-[28px] border border-black bg-[#FAFAFA] p-6 sm:p-7","children":[["$","p",null,{"className":"text-sm font-semibold uppercase tracking-[0.24em] text-blue-600","children":["Question ",6]}],["$","h2",null,{"className":"mt-3 text-2xl font-semibold tracking-[-0.04em] text-black","children":"What are the requirements to host on Discreet Set?"}],["$","p",null,{"className":"mt-4 text-base leading-7 text-black/75","children":"Hosts should control the property or have permission to list it, provide accurate photos and rules, disclose access limitations, set realistic privacy expectations, and be comfortable receiving adult-friendly production inquiries that still must remain legal and professional."}]]}]]}]]}]}],null],null],null]},[null,["$","$L2",null,{"parallelRouterKey":"children","segmentPath":["children","faq","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/e9fda707d02ffcd3.css","precedence":"next","crossOrigin":"$undefined"}],["$","link",